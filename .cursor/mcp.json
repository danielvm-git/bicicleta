{
  "mcpServers": {
    "ctxo": {
      "command": "npx",
      "args": ["@ctxo/cli", "mcp"]
    },
    "context-mode": {
      "command": "context-mode"
    },
    "neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/mcp"
    },
    "render": {
      "url": "https://mcp.render.com/mcp",
      "headers": {
        "Authorization": "Bearer RENDER_MCP_BEARER_SET_IN_LOCAL_OVERRIDES"
      }
    }
  }
}
