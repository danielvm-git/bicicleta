{
  "name": "bicicleta",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "format:check": "prettier --check .",
    "typecheck": "nuxi typecheck",
    "prepare": "husky",
    "preflight:quick": "npm run test && npm run format:check",
    "preflight": "npm run test && npm run test:e2e && npm run format:check && npm run build"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@nuxt/ui": "^2.22.3",
    "cheerio": "^1.2.0",
    "csv-parse": "^5.5.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.0",
    "nuxt": "^3.15.0",
    "nuxt-auth-utils": "^0.5.29",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@vue/test-utils": "^2.4.8",
    "drizzle-kit": "^0.21.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs,cjs,vue,json,md,css,scss,html,yml,yaml}": "prettier --write"
  }
}
