# Neon DB Connection String
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Neon Auth — base URL from Neon Console → Auth (used by server/api/auth/[...].ts proxy)
# NUXT_NEON_AUTH_BASE_URL=https://…

# E2E (Playwright) — app URL (default matches playwright.config)
# BASE_URL=http://127.0.0.1:3000
# Optional: override API origin for helper scripts
# API_URL=http://127.0.0.1:3000/api
# TEST_ENV=local

# Mercado Livre (MELI)
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
