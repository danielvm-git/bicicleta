      <bpmndi:BPMNEdge id="Edge_Flow_HaveUX_No_Architecture" bpmnElement="Flow_HaveUX_No_Architecture"><di:waypoint x="920" y="230" /><di:waypoint x="970" y="230" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CreateUX_Architecture" bpmnElement="Flow_CreateUX_Architecture"><di:waypoint x="1040" y="160" /><di:waypoint x="1040" y="190" /></bpmndi:BPMNEdge>
