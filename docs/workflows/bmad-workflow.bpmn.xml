      <bpmndi:BPMNEdge id="Edge_Flow_Retrospective_MoreEpics" bpmnElement="Flow_Retrospective_MoreEpics"><di:waypoint x="3600" y="370" /><di:waypoint x="3660" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_MoreEpics_Yes_SprintPlan" bpmnElement="Flow_MoreEpics_Yes_SprintPlan">
        <di:waypoint x="3685" y="345" /><di:waypoint x="3685" y="120" /><di:waypoint x="2160" y="120" /><di:waypoint x="2160" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_MoreEpics_No_End" bpmnElement="Flow_MoreEpics_No_End"><di:waypoint x="3710" y="370" /><di:waypoint x="3860" y="370" /></bpmndi:BPMNEdge>
