<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  id="Definitions_BMadWorkflow"
  targetNamespace="https://bicicleta.dev/workflows/bmad">
  <bpmn:process id="Process_BMadMethodWorkflow" name="BMad Method Workflow - Standard Greenfield" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Start" name="Start">
      <bpmn:outgoing>Flow_Start_DiscoveryDecision</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_IncludeDiscovery" name="Include Discovery?">
      <bpmn:incoming>Flow_Start_DiscoveryDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Discovery_No_PRD</bpmn:outgoing>
      <bpmn:outgoing>Flow_Discovery_Yes_Brainstorm</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_BrainstormRequirements" name="Brainstorm requirements">
      <bpmn:incoming>Flow_Discovery_Yes_Brainstorm</bpmn:incoming>
      <bpmn:outgoing>Flow_Brainstorm_Market</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AnalyzeMarketSegments" name="Analyze market segments">
      <bpmn:incoming>Flow_Brainstorm_Market</bpmn:incoming>
      <bpmn:outgoing>Flow_Market_ProductBrief</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ProductBriefRequirements" name="Product brief requirements">
      <bpmn:incoming>Flow_Market_ProductBrief</bpmn:incoming>
      <bpmn:outgoing>Flow_ProductBrief_PRD</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PRD" name="PRD">
      <bpmn:incoming>Flow_Discovery_No_PRD</bpmn:incoming>
      <bpmn:incoming>Flow_ProductBrief_PRD</bpmn:incoming>
      <bpmn:outgoing>Flow_PRD_ValidatePRD</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidatePRD" name="Validate PRD completeness">
      <bpmn:incoming>Flow_PRD_ValidatePRD</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidatePRD_HaveUX</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_HaveUX" name="Have UX?">
      <bpmn:incoming>Flow_ValidatePRD_HaveUX</bpmn:incoming>
      <bpmn:outgoing>Flow_HaveUX_Yes_CreateUX</bpmn:outgoing>
      <bpmn:outgoing>Flow_HaveUX_No_Architecture</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CreateUX" name="Create UX">
      <bpmn:incoming>Flow_HaveUX_Yes_CreateUX</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateUX_Architecture</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Architecture" name="Architecture">
      <bpmn:incoming>Flow_HaveUX_No_Architecture</bpmn:incoming>
      <bpmn:incoming>Flow_CreateUX_Architecture</bpmn:incoming>
      <bpmn:outgoing>Flow_Architecture_ValidateArch</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidateArchitecture" name="Validate architecture requirements">
      <bpmn:incoming>Flow_Architecture_ValidateArch</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidateArch_EpicsStories</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EpicsStories" name="Epics/Stories">
      <bpmn:incoming>Flow_ValidateArch_EpicsStories</bpmn:incoming>
      <bpmn:outgoing>Flow_EpicsStories_TestDesign</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_TestDesignRequirements" name="Test design requirements">
      <bpmn:incoming>Flow_EpicsStories_TestDesign</bpmn:incoming>
      <bpmn:outgoing>Flow_TestDesign_ImplReadiness</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ImplementationReadiness" name="Implementation readiness">
      <bpmn:incoming>Flow_TestDesign_ImplReadiness</bpmn:incoming>
      <bpmn:outgoing>Flow_ImplReadiness_SprintPlan</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SprintPlan" name="Sprint Plan">
      <bpmn:incoming>Flow_ImplReadiness_SprintPlan</bpmn:incoming>
      <bpmn:incoming>Flow_MoreEpics_Yes_SprintPlan</bpmn:incoming>
      <bpmn:outgoing>Flow_SprintPlan_CreateStory</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CreateStory" name="Create Story">
      <bpmn:incoming>Flow_SprintPlan_CreateStory</bpmn:incoming>
      <bpmn:incoming>Flow_MoreStories_Yes_CreateStory</bpmn:incoming>
      <bpmn:incoming>Flow_CodeReview_Fail_CreateStory</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateStory_ValidateStory</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidateStoryAcceptance" name="Validate story acceptance">
      <bpmn:incoming>Flow_CreateStory_ValidateStory</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidateStory_DevelopStory</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DevelopStory" name="Develop Story">
      <bpmn:incoming>Flow_ValidateStory_DevelopStory</bpmn:incoming>
      <bpmn:outgoing>Flow_DevelopStory_CodeReviewWithLLMs</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CodeReviewDifferentLLMs" name="Code review with different LLMs">
      <bpmn:incoming>Flow_DevelopStory_CodeReviewWithLLMs</bpmn:incoming>
      <bpmn:outgoing>Flow_CodeReviewWithLLMs_PassDecision</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_CodeReviewPass" name="Code Review Pass?">
      <bpmn:incoming>Flow_CodeReviewWithLLMs_PassDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_CodeReview_Fail_CreateStory</bpmn:outgoing>
      <bpmn:outgoing>Flow_CodeReview_Pass_MoreStories</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_MoreStoriesInEpic" name="More Stories in Epic?">
      <bpmn:incoming>Flow_CodeReview_Pass_MoreStories</bpmn:incoming>
      <bpmn:outgoing>Flow_MoreStories_Yes_CreateStory</bpmn:outgoing>
      <bpmn:outgoing>Flow_MoreStories_No_Retrospective</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Retrospective" name="Retrospective">
      <bpmn:incoming>Flow_MoreStories_No_Retrospective</bpmn:incoming>
      <bpmn:outgoing>Flow_Retrospective_MoreEpics</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_MoreEpics" name="More Epics?">
      <bpmn:incoming>Flow_Retrospective_MoreEpics</bpmn:incoming>
      <bpmn:outgoing>Flow_MoreEpics_Yes_SprintPlan</bpmn:outgoing>
      <bpmn:outgoing>Flow_MoreEpics_No_End</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_End" name="End">
      <bpmn:incoming>Flow_MoreEpics_No_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_DiscoveryDecision" sourceRef="StartEvent_Start" targetRef="Gateway_IncludeDiscovery" />
    <bpmn:sequenceFlow id="Flow_Discovery_No_PRD" sourceRef="Gateway_IncludeDiscovery" targetRef="Task_PRD" name="No" />
    <bpmn:sequenceFlow id="Flow_Discovery_Yes_Brainstorm" sourceRef="Gateway_IncludeDiscovery" targetRef="Task_BrainstormRequirements" name="Yes" />
    <bpmn:sequenceFlow id="Flow_Brainstorm_Market" sourceRef="Task_BrainstormRequirements" targetRef="Task_AnalyzeMarketSegments" />
    <bpmn:sequenceFlow id="Flow_Market_ProductBrief" sourceRef="Task_AnalyzeMarketSegments" targetRef="Task_ProductBriefRequirements" />
    <bpmn:sequenceFlow id="Flow_ProductBrief_PRD" sourceRef="Task_ProductBriefRequirements" targetRef="Task_PRD" />
    <bpmn:sequenceFlow id="Flow_PRD_ValidatePRD" sourceRef="Task_PRD" targetRef="Task_ValidatePRD" />
    <bpmn:sequenceFlow id="Flow_ValidatePRD_HaveUX" sourceRef="Task_ValidatePRD" targetRef="Gateway_HaveUX" />
    <bpmn:sequenceFlow id="Flow_HaveUX_Yes_CreateUX" sourceRef="Gateway_HaveUX" targetRef="Task_CreateUX" name="Yes" />
    <bpmn:sequenceFlow id="Flow_HaveUX_No_Architecture" sourceRef="Gateway_HaveUX" targetRef="Task_Architecture" name="No" />
    <bpmn:sequenceFlow id="Flow_CreateUX_Architecture" sourceRef="Task_CreateUX" targetRef="Task_Architecture" />
    <bpmn:sequenceFlow id="Flow_Architecture_ValidateArch" sourceRef="Task_Architecture" targetRef="Task_ValidateArchitecture" />
    <bpmn:sequenceFlow id="Flow_ValidateArch_EpicsStories" sourceRef="Task_ValidateArchitecture" targetRef="Task_EpicsStories" />
    <bpmn:sequenceFlow id="Flow_EpicsStories_TestDesign" sourceRef="Task_EpicsStories" targetRef="Task_TestDesignRequirements" />
    <bpmn:sequenceFlow id="Flow_TestDesign_ImplReadiness" sourceRef="Task_TestDesignRequirements" targetRef="Task_ImplementationReadiness" />
    <bpmn:sequenceFlow id="Flow_ImplReadiness_SprintPlan" sourceRef="Task_ImplementationReadiness" targetRef="Task_SprintPlan" />
    <bpmn:sequenceFlow id="Flow_SprintPlan_CreateStory" sourceRef="Task_SprintPlan" targetRef="Task_CreateStory" />
    <bpmn:sequenceFlow id="Flow_CreateStory_ValidateStory" sourceRef="Task_CreateStory" targetRef="Task_ValidateStoryAcceptance" />
    <bpmn:sequenceFlow id="Flow_ValidateStory_DevelopStory" sourceRef="Task_ValidateStoryAcceptance" targetRef="Task_DevelopStory" />
    <bpmn:sequenceFlow id="Flow_DevelopStory_CodeReviewWithLLMs" sourceRef="Task_DevelopStory" targetRef="Task_CodeReviewDifferentLLMs" />
    <bpmn:sequenceFlow id="Flow_CodeReviewWithLLMs_PassDecision" sourceRef="Task_CodeReviewDifferentLLMs" targetRef="Gateway_CodeReviewPass" />
    <bpmn:sequenceFlow id="Flow_CodeReview_Fail_CreateStory" sourceRef="Gateway_CodeReviewPass" targetRef="Task_CreateStory" name="Fail" />
    <bpmn:sequenceFlow id="Flow_CodeReview_Pass_MoreStories" sourceRef="Gateway_CodeReviewPass" targetRef="Gateway_MoreStoriesInEpic" name="Pass" />
    <bpmn:sequenceFlow id="Flow_MoreStories_Yes_CreateStory" sourceRef="Gateway_MoreStoriesInEpic" targetRef="Task_CreateStory" name="Yes" />
    <bpmn:sequenceFlow id="Flow_MoreStories_No_Retrospective" sourceRef="Gateway_MoreStoriesInEpic" targetRef="Task_Retrospective" name="No" />
    <bpmn:sequenceFlow id="Flow_Retrospective_MoreEpics" sourceRef="Task_Retrospective" targetRef="Gateway_MoreEpics" />
    <bpmn:sequenceFlow id="Flow_MoreEpics_Yes_SprintPlan" sourceRef="Gateway_MoreEpics" targetRef="Task_SprintPlan" name="Yes" />
    <bpmn:sequenceFlow id="Flow_MoreEpics_No_End" sourceRef="Gateway_MoreEpics" targetRef="EndEvent_End" name="No" />
  </bpmn:process>
