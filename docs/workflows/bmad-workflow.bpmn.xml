      <bpmndi:BPMNEdge id="Edge_Flow_PRD_ValidatePRD" bpmnElement="Flow_PRD_ValidatePRD"><di:waypoint x="610" y="230" /><di:waypoint x="670" y="230" /></bpmndi:BPMNEdge>
